<!DOCTYPE html>
<html lang="en" data-theme="night">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grand Line Registry - 404</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="bg-[#07142c] min-h-screen text-white">
  <%- include("partials/navbar", { title: "Lost at Sea" }) %>

  <main class="px-3 md:px-6 py-16">
    <div class="text-center">
      <h1 class="text-5xl font-bold mb-6">404</h1>
      <p class="text-lg text-white/60 mb-8"><%= message %></p>
      <a href="/" class="btn btn-sm bg-sky-400 hover:bg-sky-300 text-black border-0 rounded-lg px-6">
        Return Home
      </a>
    </div>
  </main>
</body>
</html>