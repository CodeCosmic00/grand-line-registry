<!DOCTYPE html>
<html lang="en" data-theme="night">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grand Line Registry - Log Pose</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="bg-[#07142c] min-h-screen text-white">
  <%- include("partials/navbar", { title: "Secret Log Pose" }) %>

  <main class="px-3 md:px-6 py-8">
    <div class="alert bg-sky-500 text-black border-0 rounded-3xl text-sm mb-8">
      <span>
        <strong class="uppercase tracking-widest">Last Request:</strong>
        <%= log %>
      </span>
    </div>

    <section class="mb-8">
      <h1 class="text-4xl font-bold text-white mb-3">
        🗺️ Destination Reached: Laugh Tale
      </h1>
      <p class="text-white/45 text-lg">
        You've made it to the final island at the end of the Grand Line. Only the most determined pirates reach this place. Listed below are the active crew members who completed the journey.
      </p>
    </section>

    <h2 class="text-2xl font-bold mb-6">Active Crew Members</h2>

    <div class="overflow-x-auto">
      <table class="table w-full text-base">
        <thead class="text-white/50 text-sm">
          <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Bounty (Berries)</th>
          </tr>
        </thead>
        <tbody>
          <% for (const member of crew) { %>
            <% if (member.status === "active") { %>
              <tr class="border-b border-white/5 hover:bg-white/3">
                <td class="font-bold text-white"><%= member.name %></td>
                <td><%= member.role %></td>
                <td><%= member.bounty.toLocaleString() %></td>
              </tr>
            <% } %>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>