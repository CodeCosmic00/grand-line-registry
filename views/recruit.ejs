<!DOCTYPE html>
<html lang="en" data-theme="night">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grand Line Registry - Recruit</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="bg-[#07142c] min-h-screen text-white">
  <%- include("partials/navbar", { title: "Join the Crew" }) %>

  <main class="px-3 md:px-6 py-8">
    <section class="mb-8">
      <h1 class="text-4xl font-bold text-white">Recruit Application</h1>
      <p class="text-white/45 text-lg mt-2">
        Think you have what it takes to sail the Grand Line?
      </p>
    </section>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-error mb-6 text-sm">
        <div>
          <ul class="list-disc ml-6">
            <% errors.forEach(error => { %>
              <li><%= error %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    <% } %>

    <% if (successMessage) { %>
      <div class="alert alert-success mb-6 text-sm">
        <span><%= successMessage %></span>
      </div>
    <% } %>

    <form action="/recruit" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-lg mb-2">Your Name</label>
          <input
            type="text"
            name="applicantName"
            value="<%= formData.applicantName || '' %>"
            placeholder="Enter your name"
            class="input input-bordered w-full bg-transparent border-white/15 text-white text-base"
          />
        </div>

        <div>
          <label class="block text-lg mb-2">Special Skill</label>
          <input
            type="text"
            name="skill"
            value="<%= formData.skill || '' %>"
            placeholder="e.g. Swordsmanship, Navigation"
            class="input input-bordered w-full bg-transparent border-white/15 text-white text-base"
          />
        </div>

        <div>
          <label class="block text-lg mb-2">Desired Role</label>
          <select
            name="role"
            class="select select-bordered w-full bg-transparent border-white/15 text-white text-base"
          >
            <option <%= !formData.role ? "selected" : "" %>>Select a role</option>
            <option value="Navigator" <%= formData.role === "Navigator" ? "selected" : "" %>>Navigator</option>
            <option value="Cook" <%= formData.role === "Cook" ? "selected" : "" %>>Cook</option>
            <option value="Sniper" <%= formData.role === "Sniper" ? "selected" : "" %>>Sniper</option>
            <option value="Doctor" <%= formData.role === "Doctor" ? "selected" : "" %>>Doctor</option>
            <option value="Musician" <%= formData.role === "Musician" ? "selected" : "" %>>Musician</option>
            <option value="Other" <%= formData.role === "Other" ? "selected" : "" %>>Other</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 items-start">
        <div class="lg:col-span-2">
          <label class="block text-lg mb-2">Why should Luffy let you join?</label>
          <textarea
            name="message"
            rows="5"
            placeholder="Explain your dream and what you bring to the crew..."
            class="textarea textarea-bordered w-full bg-transparent border-white/15 text-white text-base"
          ><%= formData.message || '' %></textarea>
        </div>

        <div>
          <label class="block text-lg mb-3">Preferred Sea</label>
          <div class="space-y-3 text-base">
            <label class="flex items-center gap-3">
              <input type="radio" name="sea" value="East Blue" class="radio radio-sm" <%= formData.sea === "East Blue" ? "checked" : "" %> />
              <span>East Blue</span>
            </label>
            <label class="flex items-center gap-3">
              <input type="radio" name="sea" value="West Blue" class="radio radio-sm" <%= formData.sea === "West Blue" ? "checked" : "" %> />
              <span>West Blue</span>
            </label>
            <label class="flex items-center gap-3">
              <input type="radio" name="sea" value="North Blue" class="radio radio-sm" <%= formData.sea === "North Blue" ? "checked" : "" %> />
              <span>North Blue</span>
            </label>
            <label class="flex items-center gap-3">
              <input type="radio" name="sea" value="South Blue" class="radio radio-sm" <%= formData.sea === "South Blue" ? "checked" : "" %> />
              <span>South Blue</span>
            </label>
          </div>
        </div>
      </div>

      <label class="flex items-center gap-3 text-base">
        <input
          type="checkbox"
          name="agreeTerms"
          class="checkbox checkbox-sm"
          <%= formData.agreeTerms ? "checked" : "" %>
        />
        <span>I understand the risks of the Grand Line</span>
      </label>

      <button
        type="submit"
        class="btn btn-sm w-full bg-sky-400 hover:bg-sky-300 text-black border-0 rounded-lg"
      >
        Submit Application
      </button>
    </form>
  </main>
</body>
</html>